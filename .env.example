# FinRadar MCP — configuration
# Copy this file to ".env" OR (recommended) just let the Claude agent store your token
# in ~/.finradar/token during setup. Never commit your real token.

# Your personal FinRadar token (generated in the web app: profile → "AI agent").
FINRADAR_TOKEN=frad_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The FinRadar instance to talk to. Leave as-is unless told otherwise.
FINRADAR_BASE_URL=https://finradar.lab.vanbe.be
